<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MIDI Player with Custom SoundFont</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            background-color: #1a1a1a;
            color: white;
            margin: 0;
        }
        .container {
            background: #2a2a2a;
            padding: 2rem;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            text-align: center;
            width: 400px;
        }
        .input-group {
            margin-bottom: 1.5rem;
            text-align: left;
        }
        label {
            display: block;
            margin-bottom: 0.5rem;
            font-size: 0.9rem;
            color: #aaa;
        }
        input[type="file"] {
            width: 100%;
            padding: 10px;
            background: #333;
            border: 1px border #444;
            border-radius: 4px;
            color: white;
            cursor: pointer;
        }
        .controls {
            margin-top: 2rem;
        }
        button {
            padding: 10px 20px;
            font-size: 1rem;
            cursor: pointer;
            border: none;
            border-radius: 4px;
            background: #007bff;
            color: white;
            transition: background 0.2s;
        }
        button:disabled {
            background: #555;
            cursor: not-allowed;
        }
        #status {
            margin-top: 1rem;
            font-size: 0.8rem;
            color: #00ff00;
        }
    </style>
</head>
<body>

<div class="container">
    <h1>MIDI Player</h1>
    <p>Using: 201507w165RO-0.sf2</p>

    <div class="input-group">
        <label>1. Load SoundFont (.sf2)</label>
        <input type="file" id="sf2-file" accept=".sf2">
    </div>

    <div class="input-group">
        <label>2. Load MIDI File (.mid)</label>
        <input type="file" id="midi-file" accept=".mid,.midi">
    </div>

    <div class="controls">
        <button id="play-btn" disabled>Play MIDI</button>
        <button id="stop-btn" disabled>Stop</button>
    </div>

    <div id="status">Ready. Please upload the SoundFont first.</div>
</div>

<script type="module">
    import { Synthetizer, MidiPlayer } from "https://spessasynth.github.io/spessasynth/src/spessasynth.js";

    let synth;
    let player;
    let audioContext;

    const sf2Input = document.getElementById('sf2-file');
    const midiInput = document.getElementById('midi-file');
    const playBtn = document.getElementById('play-btn');
    const stopBtn = document.getElementById('stop-btn');
    const status = document.getElementById('status');

    // Handle SoundFont Loading
    sf2Input.onclick = () => {
        if (!audioContext) {
            audioContext = new AudioContext();
        }
    };

    sf2Input.onchange = async (e) => {
        const file = e.target.files[0];
        if (!file) return;

        status.innerText = "Loading SoundFont...";
        const buffer = await file.arrayBuffer();
        
        // Initialize Synthesizer with the SF2 buffer
        synth = new Synthetizer(audioContext.destination, buffer);
        status.innerText = "SoundFont Loaded! Now select a MIDI.";
        checkReady();
    };

    function checkReady() {
        if (synth && midiInput.files.length > 0) {
            playBtn.disabled = false;
        }
    }

    midiInput.onchange = checkReady;

    // Handle Playback
    playBtn.onclick = async () => {
        if (audioContext.state === 'suspended') {
            await audioContext.resume();
        }

        const midiFile = midiInput.files[0];
        const midiBuffer = await midiFile.arrayBuffer();

        if (player) {
            player.stop();
        }

        // Create player and connect to synth
        player = new MidiPlayer(midiBuffer, synth);
        player.play();
        
        status.innerText = "Playing: " + midiFile.name;
        stopBtn.disabled = false;
    };

    stopBtn.onclick = () => {
        if (player) {
            player.stop();
            status.innerText = "Stopped.";
        }
    };
</script>

</body>
</html>
